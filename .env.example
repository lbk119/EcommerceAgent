# LLM Backend, OpenAI-compatible
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your-api-key
LLM_MODEL=qwen-max
LLM_PROVIDER=openai
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.2

# Optional model profiles
FAST_LLM_MODEL=qwen-turbo
FAST_LLM_PROVIDER=openai
FAST_LLM_TIMEOUT_SECONDS=180
FAST_LLM_MAX_RETRIES=3
FAST_LLM_TEMPERATURE=0.2
REASONING_LLM_MODEL=qwen-max
REASONING_LLM_PROVIDER=openai
REASONING_LLM_TIMEOUT_SECONDS=180
REASONING_LLM_MAX_RETRIES=3
REASONING_LLM_TEMPERATURE=0.2
CRITIC_LLM_MODEL=qwen-max
CRITIC_LLM_PROVIDER=openai
CRITIC_LLM_TIMEOUT_SECONDS=180
CRITIC_LLM_MAX_RETRIES=3
CRITIC_LLM_TEMPERATURE=0.0

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=ecommerce_demo
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_SQL_MODE=TRADITIONAL

# Redis checkpoint / Redis queue
CHECKPOINTER_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# Milvus memory vector backend
MEMORY_VECTOR_BACKEND=milvus
MEMORY_VECTOR_SEARCH_ENABLED=false
MEMORY_VECTOR_WRITE_ENABLED=false
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_INDEX_TYPE=HNSW
MILVUS_EF=64
MILVUS_NPROBE=10
MEMORY_MILVUS_COLLECTION=agent_memories

# Memory embedding
MEMORY_EMBEDDING_ENABLED=false
MEMORY_EMBEDDING_PROVIDER=local_bge_m3
MEMORY_EMBEDDING_MODEL=BAAI/bge-m3
MEMORY_EMBEDDING_DIM=1024
MEMORY_EMBEDDING_API_KEY=
MEMORY_EMBEDDING_BASE_URL=
BGE_M3=BAAI/bge-m3
BGE_M3_PATH=
BGE_DEVICE=cpu
BGE_FP16=0
BGE_PROCESS_MODE=worker
BGE_WORKER_TIMEOUT_SECONDS=300

# Task queue: inline / redis / nats
TASK_QUEUE_BACKEND=inline
TASK_QUEUE_NAME=deepagent.tasks
MAX_AGENT_CONCURRENCY=2
NATS_URL=nats://localhost:4222

# Agent runtime / loop guard / trace
AGENT_RECURSION_LIMIT=50
AGENT_LOOP_REFLECTION_RETRIES=1
AGENT_SUPERVISOR_ENABLED=true
AGENT_SUPERVISOR_INTERVAL=10
AGENT_SUPERVISOR_NEAR_LIMIT_MARGIN=5
AGENT_TRACE_PATH=data/memory/agent_traces.jsonl
AGENT_TRACE_QUEUE_SIZE=1000
TOOL_PERMISSION_ENFORCEMENT=true

# Gateway auth / Casbin
PYTHON_BRAIN_URL=http://127.0.0.1:9000
GATEWAY_ADDR=:9090
GIN_MODE=debug
OUTPUT_DIR=output
GATEWAY_AUTH_ENABLED=true
GATEWAY_USER_STORE_BACKEND=static
GATEWAY_JWT_SECRET=dev-only-change-me
GATEWAY_JWT_EXPIRES_SECONDS=7200
GATEWAY_CASBIN_MODEL=gateway/configs/casbin/model.conf
GATEWAY_CASBIN_POLICY=gateway/configs/casbin/policy.csv
GATEWAY_DEMO_USER_ID=local_user
GATEWAY_DEMO_PASSWORD=admin123
GATEWAY_DEMO_USER_NAME=local_admin
GATEWAY_DEMO_TENANT_ID=tenant_demo
GATEWAY_DEMO_TENANT_IDS=tenant_demo
GATEWAY_DEMO_SHOP_ID=default_shop
GATEWAY_DEMO_SHOP_IDS=default_shop
GATEWAY_DEMO_ROLES=admin
GATEWAY_DEMO_PERMISSIONS=task:create,task:read,task:cancel,task:resume,file:upload,file:download,file:list,memory:read,memory:review,memory:approve,memory:reject,policy:read,policy:approve,policy:reject,trace:read,metrics:read,tool:database:read,tool:network:search,tool:kb:ask

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:9090
VITE_WS_BASE_URL=ws://127.0.0.1:9090

# RAGFlow, optional
RAGFLOW_API_URL=http://your-ragflow-host
RAGFLOW_API_KEY=your-ragflow-key

# Tavily, optional
TAVILY_API_KEY=your-tavily-key

# Critic
CRITIC_ENABLED=true
CRITIC_MAX_REVISIONS=1

# Database workflow / guard / write protection
DB_AGENT_MAX_TOOL_CALLS=10
DB_AGENT_MAX_SCHEMA_CALLS=5
DB_AGENT_MAX_SQL_CALLS=4
DB_GRAPH_MAX_ROUNDS=8
DB_GRAPH_MAX_SQL_FAILURES=2
DB_GRAPH_MAX_SCHEMA_TABLES=5
DB_SANDBOX_DATABASE=
DB_ALLOW_DANGEROUS_DDL=false
DB_ENABLE_PRODUCTION_MERGE=false
