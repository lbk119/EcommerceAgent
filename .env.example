# LLM Backend, OpenAI-compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.2

# Commercial model tiers
# Fast tier: AI chat, standard workflows, reducers, evaluation/supervisor checks.
# Deep tier: explicitly deep Agent tasks only.
LLM_FAST_MODEL=gpt-5.4-mini
LLM_DEEP_MODEL=gpt-5.5
LLM_FAST_TIMEOUT_SECONDS=8
LLM_FAST_MAX_RETRIES=1
LLM_DEEP_TIMEOUT_SECONDS=60
LLM_DEEP_MAX_RETRIES=1

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
# Required. Set this to your local MySQL password before running scripts/start-dev.ps1.
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=ecommerce_demo
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_SQL_MODE=TRADITIONAL

# Redis checkpoint / Redis queue
CHECKPOINTER_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# Milvus memory vector backend
MEMORY_VECTOR_BACKEND=milvus
MEMORY_VECTOR_SEARCH_ENABLED=false
MEMORY_VECTOR_WRITE_ENABLED=false
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_INDEX_TYPE=HNSW
MILVUS_EF=64
MILVUS_NPROBE=10
MEMORY_MILVUS_COLLECTION=agent_memories

# Memory embedding
MEMORY_EMBEDDING_ENABLED=false
MEMORY_EMBEDDING_PROVIDER=local_bge_m3
MEMORY_EMBEDDING_MODEL=BAAI/bge-m3
MEMORY_EMBEDDING_DIM=1024
MEMORY_EMBEDDING_API_KEY=
MEMORY_EMBEDDING_BASE_URL=
BGE_M3=BAAI/bge-m3
BGE_M3_PATH=
BGE_DEVICE=cpu
BGE_FP16=0
BGE_PROCESS_MODE=worker
BGE_WORKER_TIMEOUT_SECONDS=300

# Task queue: inline / redis / nats
TASK_QUEUE_BACKEND=inline
TASK_QUEUE_NAME=deepagent.tasks
MAX_AGENT_CONCURRENCY=10
REALTIME_AGENT_CONCURRENCY=8
STANDARD_AGENT_CONCURRENCY=2
DEEP_AGENT_CONCURRENCY=1
NATS_URL=nats://localhost:4222

# Agent runtime / loop guard / trace
AGENT_RECURSION_LIMIT=50
AGENT_LOOP_REFLECTION_RETRIES=1
AGENT_SUPERVISOR_ENABLED=true
AGENT_SUPERVISOR_INTERVAL=10
AGENT_SUPERVISOR_NEAR_LIMIT_MARGIN=5
AGENT_TRACE_PATH=data/memory/agent_traces.jsonl
AGENT_TRACE_QUEUE_SIZE=1000
TOOL_PERMISSION_ENFORCEMENT=true

# Docker sandbox
ENABLE_DOCKER_SANDBOX=true
SANDBOX_SERVER_INTERNAL_TOKEN=dev-sandbox-token-change-me
SANDBOX_SERVER_URL=http://127.0.0.1:9000
SANDBOX_ROOT=output/sandbox
SANDBOX_KEEP_WORKSPACE_ON_FAILURE=false
SANDBOX_DEFAULT_TIMEOUT_SECONDS=30
SANDBOX_MAX_TIMEOUT_SECONDS=120
SANDBOX_DEFAULT_MEMORY_MB=512
SANDBOX_DEEP_MEMORY_MB=1024
SANDBOX_DEFAULT_CPU_COUNT=1
SANDBOX_DEEP_CPU_COUNT=2
SANDBOX_PIDS_LIMIT=128
SANDBOX_MAX_INPUT_BYTES=10485760
SANDBOX_MAX_OUTPUT_BYTES=10485760
SANDBOX_ENABLE_NETWORK=false
SANDBOX_DEEP_ENABLE_NETWORK=false
SANDBOX_ALLOWED_DOMAINS=
SANDBOX_ENABLE_SHELL=false
SANDBOX_PYTHON_IMAGE=ecommerce-agent-sandbox-python:latest
SANDBOX_NODE_IMAGE=ecommerce-agent-sandbox-node:latest

# AI Chat commercial runtime defaults
AI_CHAT_MODEL_PROFILE=fast
AGENT_REPORT_MODEL_PROFILE=standard
AI_CHAT_LLM_TIMEOUT_SECONDS=8
AI_CHAT_LLM_MAX_RETRIES=1
AI_CHAT_TOTAL_TARGET_SECONDS=15
AI_CHAT_MAX_RUNTIME_SECONDS=180
AI_CHAT_DEEPAGENT_ENABLED=false
REALTIME_AGENT_MAX_WALL_TIME_SECONDS=15
REALTIME_AGENT_MAX_MODEL_CALLS=1
REALTIME_AGENT_MAX_TOOL_CALLS=3
REALTIME_AGENT_MAX_SUBAGENT_CALLS=0
REALTIME_PLAN_STEP_TIMEOUT_SECONDS=2
REALTIME_PLAN_GLOBAL_TIMEOUT_SECONDS=8
REALTIME_PLAN_POLISH_TIMEOUT_SECONDS=3
REALTIME_PLAN_FAST_POLISH=false
STANDARD_AGENT_MAX_WALL_TIME_SECONDS=45
STANDARD_AGENT_MAX_MODEL_CALLS=2
STANDARD_AGENT_MAX_TOOL_CALLS=6
STANDARD_AGENT_MAX_SUBAGENT_CALLS=1
STANDARD_PLAN_STEP_TIMEOUT_SECONDS=2
STANDARD_PLAN_GLOBAL_TIMEOUT_SECONDS=30
STANDARD_PLAN_POLISH_TIMEOUT_SECONDS=6
STANDARD_PLAN_FAST_POLISH=false
STANDARD_AGENT_ALLOW_DEEPAGENT_FALLBACK=false
DEEP_AGENT_MAX_WALL_TIME_SECONDS=180
DEEP_AGENT_MAX_MODEL_CALLS=6
DEEP_AGENT_MAX_TOOL_CALLS=12
DEEP_AGENT_MAX_SUBAGENT_CALLS=3
DEEP_PLAN_STEP_TIMEOUT_SECONDS=3
DEEP_PLAN_GLOBAL_TIMEOUT_SECONDS=60
DEEP_PLAN_POLISH_TIMEOUT_SECONDS=8
DEEP_PLAN_FAST_POLISH=true
DEEPAGENTS_DEEP_ENABLE_NETWORK_SEARCH=true
AGENT_HOT_PATH_MEMORY_WRITE=false

# Gateway auth / Casbin
PYTHON_BRAIN_URL=http://127.0.0.1:9000
GATEWAY_ADDR=:9090
GIN_MODE=debug
OUTPUT_DIR=output
GATEWAY_AUTH_ENABLED=true
GATEWAY_USER_STORE_BACKEND=mysql
GATEWAY_JWT_SECRET=dev-only-change-me
GATEWAY_JWT_EXPIRES_SECONDS=7200
GATEWAY_CASBIN_MODEL=gateway/configs/casbin/model.conf
GATEWAY_CASBIN_POLICY=gateway/configs/casbin/policy.csv
GATEWAY_DEMO_USER_ID=local_user
GATEWAY_DEMO_PASSWORD=admin123
GATEWAY_DEMO_USER_NAME=local_admin
GATEWAY_DEMO_TENANT_ID=tenant_demo
GATEWAY_DEMO_TENANT_IDS=tenant_demo
GATEWAY_DEMO_SHOP_ID=default_shop
GATEWAY_DEMO_SHOP_IDS=default_shop
GATEWAY_DEMO_ROLES=admin
GATEWAY_DEMO_PERMISSIONS=task:create,task:read,task:cancel,task:resume,file:upload,file:download,file:list,memory:read,memory:review,memory:approve,memory:reject,policy:read,policy:approve,policy:reject,trace:read,metrics:read,tool:database:read,tool:network:search,tool:kb:ask

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:9090
VITE_WS_BASE_URL=ws://127.0.0.1:9090

# RAGFlow, optional
RAGFLOW_API_URL=http://your-ragflow-host
RAGFLOW_API_KEY=your-ragflow-key

# Tavily, optional
TAVILY_API_KEY=your-tavily-key

# Evaluation
EVALUATION_ENABLED=true
EVALUATION_MAX_REVISIONS=1

# Database workflow / guard / write protection
DB_AGENT_MAX_TOOL_CALLS=10
DB_AGENT_MAX_SCHEMA_CALLS=5
DB_AGENT_MAX_SQL_CALLS=4
DB_GRAPH_MAX_ROUNDS=8
DB_GRAPH_MAX_SQL_FAILURES=2
DB_GRAPH_MAX_SCHEMA_TABLES=5
DB_SANDBOX_DATABASE=
DB_ALLOW_DANGEROUS_DDL=false
DB_ENABLE_PRODUCTION_MERGE=false
